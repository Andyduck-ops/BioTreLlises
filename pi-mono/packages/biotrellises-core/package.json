{
	"name": "@mariozechner/biotrellises-core",
	"version": "0.1.0",
	"description": "BioTreLlises bioinformatics AI agent core library",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"biotrellises": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.70.5",
		"@mariozechner/pi-ai": "^0.70.5",
		"@mariozechner/pi-tui": "^0.70.5",
		"typebox": "^1.1.24"
	},
	"keywords": [
		"ai",
		"agent",
		"bioinformatics",
		"biology",
		"llm"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/pi-mono.git",
		"directory": "packages/biotrellises-core"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"nock": "^14.0.13",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
